!
!
version 15.2
service timestamps debug datetime msec
service timestamps log datetime msec
hostname PE2
!
ip cef
mpls label protocol ldp
mpls ldp router-id Loopback0 force
!
ip vrf VRF_CE13
 rd 100:130
 route-target export 100:130
 route-target import 100:130
!
ip vrf VRF_CE24
 rd 100:240
 route-target export 100:240
 route-target import 100:240
!
interface Loopback0
 ip address 10.255.255.6 255.255.255.255
!
interface FastEthernet1/0
 ip address 10.0.0.17 255.255.255.252
 ip ospf cost 10
 mpls ip
 no shutdown
!
interface GigabitEthernet0/0
 ip vrf forwarding VRF_CE13
 ip address 10.0.0.20 255.255.255.252
 no shutdown
!
interface FastEthernet1/0
 ip vrf forwarding VRF_CE24
 ip address 10.0.0.24 255.255.255.252
 no shutdown
!
router ospf 1
 router-id 10.255.255.6
 network 10.0.0.16 0.0.0.3 area 0
 network 10.255.255.6 0.0.0.0 area 0
!
router bgp 100
 bgp router-id 10.255.255.6
 bgp log-neighbor-changes
 neighbor 10.0.0.21 remote-as 130
 neighbor 10.0.0.21 send-community
 neighbor 10.0.0.21 route-map RM-IN-CUSTOMER in
 neighbor 10.0.0.21 route-map RM-OUT-TO-CUSTOMER out
 neighbor 10.0.0.21 soft-reconfiguration inbound
 neighbor 10.0.0.21 next-hop-self
 neighbor 10.0.0.25 remote-as 240
 neighbor 10.0.0.25 send-community
 neighbor 10.0.0.25 route-map RM-IN-CUSTOMER in
 neighbor 10.0.0.25 route-map RM-OUT-TO-CUSTOMER out
 neighbor 10.0.0.25 soft-reconfiguration inbound
 neighbor 10.0.0.25 next-hop-self
!
