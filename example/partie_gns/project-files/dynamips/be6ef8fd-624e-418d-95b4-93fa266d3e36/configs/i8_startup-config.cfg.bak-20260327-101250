!
!
!
version 15.2
service timestamps debug datetime msec
service timestamps log datetime msec
hostname CE4
!
ip cef
!
interface Loopback0
 ip address 10.255.255.8 255.255.255.255
!
interface GigabitEthernet0/0
 ip address 10.0.0.25 255.255.255.252
 ip ospf cost 10
no shutdown
!
router ospf 1
 router-id 10.255.255.8
 network 10.0.0.24 0.0.0.3 area 0
 network 10.255.255.8 0.0.0.0 area 0
!
router bgp 240
 bgp router-id 10.255.255.8
 bgp log-neighbor-changes
 neighbor 10.0.0.24 remote-as 100
 neighbor 10.0.0.24 send-community
 neighbor 10.0.0.24 route-map RM-IN-PROVIDER in
 neighbor 10.0.0.24 route-map RM-OUT-TO-PROVIDER out
 neighbor 10.0.0.24 soft-reconfiguration inbound
 neighbor 10.0.0.24 next-hop-self
!
