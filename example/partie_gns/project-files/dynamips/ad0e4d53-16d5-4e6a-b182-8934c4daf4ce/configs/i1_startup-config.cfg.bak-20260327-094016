!
!
version 15.2
service timestamps debug datetime msec
service timestamps log datetime msec
hostname PE1
!
ip cef
mpls label protocol ldp
mpls ldp router-id Loopback0 force
!
interface Loopback0
 ip address 10.255.255.3 255.255.255.255
!
interface FastEthernet1/0
 ip address 10.0.0.2 255.255.255.252
 ip ospf cost 10
no shutdown
!
interface FastEthernet1/1
 ip address 10.0.0.6 255.255.255.252
 ip ospf cost 10
no shutdown
!
interface GigabitEthernet0/0
 ip address 10.0.0.8 255.255.255.252
 ip ospf cost 10
 mpls ip
no shutdown
!
router ospf 1
 router-id 10.255.255.3
 network 10.0.0.0 0.0.0.3 area 0
 network 10.0.0.4 0.0.0.3 area 0
 network 10.0.0.8 0.0.0.3 area 0
 network 10.255.255.3 0.0.0.0 area 0
!
router bgp 100
 bgp router-id 10.255.255.3
 bgp log-neighbor-changes
 neighbor 10.255.255.4 remote-as 100
 neighbor 10.255.255.4 update-source Loopback0
 address-family ipv4
  no neighbor 10.255.255.4 activate
 exit-address-family
 address-family vpnv4
  neighbor 10.255.255.4 activate
  neighbor 10.255.255.4 send-community extended
 exit-address-family
 neighbor 10.0.0.1 remote-as 130
 neighbor 10.0.0.1 send-community
 neighbor 10.0.0.1 route-map RM-IN-CUSTOMER in
 neighbor 10.0.0.1 route-map RM-OUT-TO-CUSTOMER out
 neighbor 10.0.0.1 soft-reconfiguration inbound
 neighbor 10.0.0.1 next-hop-self
 neighbor 10.0.0.5 remote-as 240
 neighbor 10.0.0.5 send-community
 neighbor 10.0.0.5 route-map RM-IN-CUSTOMER in
 neighbor 10.0.0.5 route-map RM-OUT-TO-CUSTOMER out
 neighbor 10.0.0.5 soft-reconfiguration inbound
 neighbor 10.0.0.5 next-hop-self
!
